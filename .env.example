# AI Provider 配置
# 推荐使用 DeepSeek（中文能力强、免费额度大）
# 获取 Key: https://platform.deepseek.com/api_keys
ANTHROPIC_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=your-api-key-here

# 如果使用 Anthropic Claude，注释上面两行，改用：
# ANTHROPIC_API_KEY=your-anthropic-key-here

# 网易云音乐 API 基础 URL（部署 NeteaseCloudMusicApiEnhanced 到 Vercel 后获得）
# 详见: https://github.com/NeteaseCloudMusicApiEnhanced/api-enhanced
# 不配置则只使用 YouTube + B站搜索（降级方案）
MUSIC_API_BASE=https://your-ncm-instance.vercel.app

# Invidious 实例 URL（可选，用于 YouTube 搜索，默认用内置公共实例列表）
# YOUTUBE_API_BASE=https://invidious.your-domain.com

# 音频存储目录（可选，默认 ~/Documents/bili）
# MUSIC_DIR=/path/to/your/music
